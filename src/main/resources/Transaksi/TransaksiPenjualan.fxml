<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="900.0" prefWidth="1100.0"
      spacing="0"
      styleClass="content-card"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Transaksi.TransaksiPenjualanController">

    <!-- ══════════════════════════════════════════════════════════════
         TOP BAR
    ═══════════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:transparent transparent #EBEBEB transparent;
                 -fx-border-width:0 0 1 0;">
        <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

        <Label text="🧾" style="-fx-font-size:22px;" />
        <VBox spacing="1">
            <Label text="Transaksi Penjualan"
                   style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1A1A1A;" />
            <Label text="Catat transaksi penjualan produk ke nasabah"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </VBox>
    </HBox>

    <!-- ══════════════════════════════════════════════════════════════
         BADAN UTAMA: FORM KIRI + DAFTAR PRODUK KANAN
    ═══════════════════════════════════════════════════════════════ -->
    <HBox spacing="0" VBox.vgrow="ALWAYS"
          style="-fx-background-color:#FAFAFA;">

        <!-- ═══ PANEL KIRI: FORM ═══════════════════════════════════ -->
        <VBox spacing="16" prefWidth="400"
              style="-fx-background-color:#FFFFFF;
                     -fx-border-color:transparent #EBEBEB transparent transparent;
                     -fx-border-width:0 1 0 0;">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Sub-judul: Transaksi Penjualan -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Region prefWidth="3" prefHeight="18"
                        style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
                <Label text="Transaksi Penjualan"
                       style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
            </HBox>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="130" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                </rowConstraints>

                <!-- ID Penjualan -->
                <Label text="ID Penjualan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtIDPenjualan" editable="false" maxWidth="Infinity"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- Tanggal -->
                <Label text="Tanggal"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <DatePicker fx:id="dpTanggal" maxWidth="Infinity"
                            style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                            GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Total Pembelian -->
                <Label text="Total Pembelian"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtTotal" editable="false" maxWidth="Infinity"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-font-weight:bold; -fx-text-fill:#1B5E20;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2" />
            </GridPane>

            <!-- Tombol Simpan -->
            <Button fx:id="btnSimpan" text="💾  Simpan"
                    onAction="#handleSimpan"
                    maxWidth="Infinity" prefHeight="40"
                    styleClass="btn,btn-simpan" />

            <!-- Sub-judul: Detail Penjualan -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Region prefWidth="3" prefHeight="18"
                        style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
                <Label text="Detail Penjualan"
                       style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
            </HBox>

            <GridPane fx:id="gridDetail" hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="130" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                </rowConstraints>

                <!-- ID Penjualan (detail) -->
                <Label text="ID Penjualan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtIDPenjualanDetail" editable="false" maxWidth="Infinity"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- ID Produk -->
                <Label text="ID Produk"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtIDProduk" editable="false" maxWidth="Infinity"
                           promptText="← Klik kartu produk"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Jumlah -->
                <Label text="Jumlah"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <TextField fx:id="txtJumlah" maxWidth="Infinity"
                           promptText="Masukkan jumlah..."
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <!-- Harga Jual -->
                <Label text="Harga Jual"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <TextField fx:id="txtHargaJual" editable="false" maxWidth="Infinity"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <!-- Subtotal -->
                <Label text="Subtotal"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtSubtotal" editable="false" maxWidth="Infinity"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-font-weight:bold; -fx-text-fill:#1565C0;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="4" />
            </GridPane>

            <!-- Tombol aksi detail -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button fx:id="btnSelesai" text="Selesai"
                        onAction="#handleSelesai"
                        prefWidth="110" prefHeight="34"
                        styleClass="btn,btn-simpan" />
                <Button fx:id="btnBatal" text="Batal"
                        onAction="#handleBatal"
                        prefWidth="100" prefHeight="34"
                        style="-fx-background-color:#F9A825; -fx-text-fill:white;
                               -fx-font-weight:bold; -fx-background-radius:6;" />
                <Button fx:id="btnTambahProduk" text="Tambah Produk"
                        onAction="#handleTambahProduk"
                        prefWidth="130" prefHeight="34"
                        style="-fx-background-color:#1565C0; -fx-text-fill:white;
                               -fx-font-weight:bold; -fx-background-radius:6;" />
            </HBox>
        </VBox>

        <!-- ═══ PANEL KANAN: DAFTAR PRODUK (kartu dinamis, desain sama dengan Master Produk) ═══ -->
        <VBox spacing="14" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Top bar kanan -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Region prefWidth="3" prefHeight="18"
                            style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
                    <Label text="Pilih Produk"
                           style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtCariProduk"
                           prefHeight="34" prefWidth="200"
                           promptText="🔍  Cari produk..."
                           style="-fx-background-radius:8; -fx-border-radius:8;
                                  -fx-border-color:#E0E0E0; -fx-font-size:12px;" />
                <Button fx:id="btnCariProduk"
                        mnemonicParsing="false" onAction="#handleCariProduk"
                        text="Cari" prefHeight="34" prefWidth="64"
                        styleClass="btn,btn-cari" />
            </HBox>

            <fx:define>
                <ToggleGroup fx:id="tgProduk" />
            </fx:define>

            <!-- Daftar kartu produk: satu kolom, dibangun & diisi otomatis dari Master Produk -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent; -fx-border-color:transparent;">
                <content>
                    <VBox fx:id="vbKartuProduk" spacing="12">
                        <padding><Insets top="2" bottom="2"/></padding>
                    </VBox>
                </content>
            </ScrollPane>
        </VBox>
    </HBox>

    <!-- ══════════════════════════════════════════════════════════════
         DETAIL TRANSAKSI (otomatis, read-only)
         Terisi setiap kali tombol "Selesai" ditekan. Sengaja tidak
         menampilkan kolom ID — hanya Nama Produk, Jumlah, dan Harga.
    ═══════════════════════════════════════════════════════════════ -->
    <VBox spacing="10" prefHeight="230"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:#EBEBEB transparent transparent transparent;
                 -fx-border-width:1 0 0 0;">
        <padding><Insets top="16" right="24" bottom="20" left="24"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <Region prefWidth="3" prefHeight="18"
                    style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
            <Label text="Detail Transaksi"
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
            <Label text="(otomatis terbentuk setiap kali produk ditambahkan)"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </HBox>

        <TableView fx:id="tblDetailPenjualan" prefHeight="170" VBox.vgrow="ALWAYS">
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
            <columns>
                <TableColumn fx:id="colNamaProdukDetail" text="Nama Produk" style="-fx-alignment:CENTER-RIGHT;" />
                <TableColumn fx:id="colJumlahDetail" text="Jumlah" style="-fx-alignment:CENTER-RIGHT;" />
                <TableColumn fx:id="colHargaDetail" text="Harga (Rp)" style="-fx-alignment:CENTER-RIGHT;" />
            </columns>
        </TableView>
    </VBox>

</VBox>
