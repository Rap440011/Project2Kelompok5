<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootTransaksi"
      prefHeight="900.0" prefWidth="1100.0"
      spacing="0"
      styleClass="content-card"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Transaksi.TransaksiPengolahanLimbahController">

    <!-- ══════════════════════════════════════════════════════════════
         TOP BAR
    ═══════════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:transparent transparent #EBEBEB transparent;
                 -fx-border-width:0 0 1 0;">
        <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

        <Label text="⚙" style="-fx-font-size:22px;" />
        <VBox spacing="1">
            <Label text="Transaksi Pengolahan Limbah"
                   style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1A1A1A;" />
            <Label text="Catat hasil pengolahan limbah menjadi produk"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </VBox>
    </HBox>

    <!-- ══════════════════════════════════════════════════════════════
         BADAN UTAMA: FORM KIRI + KARTU KANAN
    ═══════════════════════════════════════════════════════════════ -->
    <HBox spacing="0" VBox.vgrow="ALWAYS"
          style="-fx-background-color:#FAFAFA;">

        <!-- ═══ PANEL KIRI: FORM ═══════════════════════════════════ -->
        <VBox spacing="16" prefWidth="400"
              style="-fx-background-color:#FFFFFF;
                     -fx-border-color:transparent #EBEBEB transparent transparent;
                     -fx-border-width:0 1 0 0;">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Sub-judul form -->
            <HBox alignment="CENTER_LEFT" spacing="8">
                <Region prefWidth="3" prefHeight="18"
                        style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
                <Label text="Detail Transaksi"
                       style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
            </HBox>

            <GridPane hgap="12" vgap="10">
                <columnConstraints>
                    <ColumnConstraints minWidth="120" prefWidth="130" />
                    <ColumnConstraints hgrow="ALWAYS" />
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="34" />
                    <RowConstraints minHeight="80" />
                </rowConstraints>

                <!-- ID Pengolahan -->
                <Label text="ID Pengolahan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="0" />
                <TextField fx:id="txtIDPengolahan" editable="false" maxWidth="Infinity"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="0" />

                <!-- ID Produk -->
                <Label text="ID Produk"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="1" />
                <TextField fx:id="txtIDProduk" editable="false" maxWidth="Infinity"
                           promptText="← Klik kartu produk"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                                  -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="1" />

                <!-- Tanggal -->
                <Label text="Tanggal"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="2" />
                <DatePicker fx:id="jpTanggal" maxWidth="Infinity"
                            style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                            GridPane.columnIndex="1" GridPane.rowIndex="2" />

                <!-- Jenis Produk -->
                <Label text="Jenis Produk"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="3" />
                <ComboBox fx:id="cmbJenisProduk" maxWidth="Infinity"
                          GridPane.columnIndex="1" GridPane.rowIndex="3" />

                <!-- Kuantitas Hasil -->
                <Label text="Kuantitas"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="4" />
                <TextField fx:id="txtKuantitas" maxWidth="Infinity"
                           promptText="Jumlah hasil produksi..."
                           onAction="#txtKuantitasHasil"
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                           GridPane.columnIndex="1" GridPane.rowIndex="4" />

                <!-- Satuan -->
                <Label text="Satuan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="5" />
                <ComboBox fx:id="cmbSatuan" maxWidth="Infinity"
                          onAction="#cmbSaatuan"
                          GridPane.columnIndex="1" GridPane.rowIndex="5" />

                <!-- Keterangan -->
                <Label text="Keterangan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                       GridPane.columnIndex="0" GridPane.rowIndex="6" />
                <TextArea fx:id="txtKeterangan" prefRowCount="3" wrapText="true"
                          promptText="Catatan tambahan..."
                          maxWidth="Infinity"
                          style="-fx-border-color:#E0E0E0; -fx-border-radius:6;
                                 -fx-background-radius:6; -fx-font-size:12px;"
                          GridPane.columnIndex="1" GridPane.rowIndex="6" />
            </GridPane>

            <!-- Spacer dorong tombol ke bawah -->
            <Region VBox.vgrow="ALWAYS" />

            <!-- Tombol Simpan -->
            <Button fx:id="btnSimpan" text="💾  Simpan Transaksi"
                    onAction="#handleSimpan"
                    maxWidth="Infinity" prefHeight="40"
                    styleClass="btn,btn-simpan" />
        </VBox>

        <!-- ═══ PANEL KANAN: KARTU PRODUK ══════════════════════════ -->
        <VBox spacing="14" HBox.hgrow="ALWAYS">
            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>

            <!-- Top bar kanan -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Region prefWidth="3" prefHeight="18"
                            style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
                    <Label text="Pilih Produk"
                           style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
                </HBox>
                <Region HBox.hgrow="ALWAYS" />
                <TextField fx:id="txtCariProduk"
                           prefHeight="34" prefWidth="200"
                           promptText="🔍  Cari produk..."
                           style="-fx-background-radius:8; -fx-border-radius:8;
                                  -fx-border-color:#E0E0E0; -fx-font-size:12px;" />
                <Button fx:id="btnCariProduk"
                        mnemonicParsing="false" onAction="#handleCariProduk"
                        text="Cari" prefHeight="34" prefWidth="64"
                        styleClass="btn,btn-cari" />
            </HBox>

            <fx:define>
                <ToggleGroup fx:id="tgProduk" />
            </fx:define>

            <!-- Grid kartu 2 kolom -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color:transparent; -fx-border-color:transparent;">
                <content>
                    <GridPane fx:id="gpKartuProduk" hgap="14" vgap="14">
                        <padding><Insets top="2" bottom="2"/></padding>
                        <columnConstraints>
                            <ColumnConstraints percentWidth="50" />
                            <ColumnConstraints percentWidth="50" />
                        </columnConstraints>

                        <ToggleButton fx:id="cardPupukOrganikPadat"
                                      toggleGroup="$tgProduk"
                                      contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                      GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <ToggleButton fx:id="cardPupukOrganikCair"
                                      toggleGroup="$tgProduk"
                                      contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                      GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <ToggleButton fx:id="cardKompos"
                                      toggleGroup="$tgProduk"
                                      contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                      GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <ToggleButton fx:id="cardBooster"
                                      toggleGroup="$tgProduk"
                                      contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                      GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <ToggleButton fx:id="cardPupukNitrogen"
                                      toggleGroup="$tgProduk"
                                      contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                      GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <ToggleButton fx:id="cardPupukKalsium"
                                      toggleGroup="$tgProduk"
                                      contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                      GridPane.columnIndex="1" GridPane.rowIndex="2" />
                    </GridPane>
                </content>
            </ScrollPane>
        </VBox>
    </HBox>

    <!-- ══════════════════════════════════════════════════════════════
         DETAIL TRANSAKSI (otomatis, read-only)
         Terbentuk otomatis begitu user memilih kartu produk. Tidak ada
         field yang bisa diisi manual oleh user pada bagian ini.
    ═══════════════════════════════════════════════════════════════ -->
    <VBox spacing="10" prefHeight="230"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:#EBEBEB transparent transparent transparent;
                 -fx-border-width:1 0 0 0;">
        <padding><Insets top="16" right="24" bottom="20" left="24"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <Region prefWidth="3" prefHeight="18"
                    style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
            <Label text="Detail Transaksi"
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333;" />
            <Label text="(otomatis terbentuk berdasarkan produk yang dipilih)"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </HBox>

        <TableView fx:id="tblDetailTransaksi" prefHeight="170" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colIDDetail" text="ID Detail Transaksi" prefWidth="180" />
                <TableColumn fx:id="colIDPengolahanDetail" text="ID Pengolahan" prefWidth="150" />
                <TableColumn fx:id="colIDLimbah" text="ID Limbah" prefWidth="140" />
                <TableColumn fx:id="colKuantitasLimbah" text="Kuantitas Limbah" prefWidth="150" />
                <TableColumn fx:id="colSatuanLimbah" text="Satuan Limbah" prefWidth="140" />
            </columns>
        </TableView>
    </VBox>

</VBox>
