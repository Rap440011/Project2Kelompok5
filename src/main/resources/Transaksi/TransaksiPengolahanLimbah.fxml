<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="720.0" prefWidth="1100.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Transaksi.TransaksiPengolahanLimbahController">
    <children>
        <VBox layoutX="10.0" layoutY="10.0"
              prefHeight="720.0" prefWidth="1100.0"
              spacing="0" styleClass="content-card">
            <padding>
                <Insets bottom="20" left="24" right="24" top="20" />
            </padding>

            <!-- JUDUL -->
            <Label styleClass="page-title" text="Transaksi Pengolahan Limbah" />
            <Separator>
                <VBox.margin><Insets bottom="10" top="8" /></VBox.margin>
            </Separator>

            <!-- BARIS UTAMA: FORM (kiri) + DAFTAR PRODUK (kanan) -->
            <HBox spacing="24" VBox.vgrow="ALWAYS">

                <!-- ===== PANEL KIRI: FORM ===== -->
                <VBox spacing="10" HBox.hgrow="NEVER" prefWidth="440">
                    <Label style="-fx-font-weight:bold;-fx-font-size:13px;"
                           styleClass="field-label" text="Header Transaksi" />

                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="120" prefWidth="130" />
                            <ColumnConstraints hgrow="ALWAYS" />
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints minHeight="32" />
                            <RowConstraints minHeight="32" />
                            <RowConstraints minHeight="32" />
                            <RowConstraints minHeight="32" />
                            <RowConstraints minHeight="32" />
                            <RowConstraints minHeight="32" />
                            <RowConstraints minHeight="72" />
                            <RowConstraints minHeight="40" />
                        </rowConstraints>

                        <!-- ID Pengolahan -->
                        <Label styleClass="field-label" text="ID Pengolahan"
                               GridPane.columnIndex="0" GridPane.rowIndex="0" />
                        <TextField fx:id="txtIDPengolahan" editable="false" maxWidth="Infinity"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0" />

                        <!-- ID Produk -->
                        <Label styleClass="field-label" text="ID Produk"
                               GridPane.columnIndex="0" GridPane.rowIndex="1" />
                        <TextField fx:id="txtIDProduk" editable="false" maxWidth="Infinity"
                                   promptText="Klik kartu produk di kanan >"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1" />

                        <!-- Tanggal -->
                        <Label styleClass="field-label" text="Tanggal"
                               GridPane.columnIndex="0" GridPane.rowIndex="2" />
                        <DatePicker fx:id="jpTanggal" maxWidth="Infinity"
                                    GridPane.columnIndex="1" GridPane.rowIndex="2" />

                        <!-- Jenis Produk -->
                        <Label styleClass="field-label" text="Jenis Produk"
                               GridPane.columnIndex="0" GridPane.rowIndex="3" />
                        <ComboBox fx:id="cmbJenisProduk" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="3" />

                        <!-- Kuantitas Hasil -->
                        <Label styleClass="field-label" text="Kuantitas Hasil"
                               GridPane.columnIndex="0" GridPane.rowIndex="4" />
                        <TextField fx:id="txtKuantitas" maxWidth="Infinity"
                                   onAction="#txtKuantitasHasil"
                                   GridPane.columnIndex="1" GridPane.rowIndex="4" />

                        <!-- Satuan -->
                        <Label styleClass="field-label" text="Satuan"
                               GridPane.columnIndex="0" GridPane.rowIndex="5" />
                        <ComboBox fx:id="cmbSatuan" maxWidth="Infinity"
                                  onAction="#cmbSaatuan"
                                  GridPane.columnIndex="1" GridPane.rowIndex="5" />

                        <!-- Keterangan -->
                        <Label styleClass="field-label" text="Keterangan"
                               GridPane.columnIndex="0" GridPane.rowIndex="6" />
                        <TextArea fx:id="txtKeterangan" prefHeight="68" wrapText="true"
                                  maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="6" />

                        <!-- Tombol Simpan -->
                        <Button fx:id="btnSimpan" text="Simpan"
                                onAction="#handleSimpan"
                                maxWidth="Infinity" prefHeight="36"
                                styleClass="btn,btn-simpan"
                                GridPane.columnIndex="1" GridPane.rowIndex="7" />
                    </GridPane>
                </VBox>

                <Separator orientation="VERTICAL" />

                <!-- ===== PANEL KANAN: DAFTAR PRODUK (kartu template) ===== -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">

                    <!-- Top bar: judul + field cari -->
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-font-weight:bold;-fx-font-size:13px;"
                               styleClass="field-label" text="Pilih Produk" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField fx:id="txtCariProduk"
                                   prefHeight="32" prefWidth="200"
                                   promptText="🔍  Cari produk..."
                                   style="-fx-background-radius:8; -fx-border-radius:8;
                                          -fx-border-color:#E0E0E0; -fx-font-size:12px;" />
                        <Button fx:id="btnCariProduk"
                                mnemonicParsing="false" onAction="#handleCariProduk"
                                text="Cari" prefHeight="32" prefWidth="60"
                                styleClass="btn,btn-cari" />
                    </HBox>

                    <!-- Grid kartu produk (2 kolom, scroll) -->
                    <fx:define>
                        <ToggleGroup fx:id="tgProduk" />
                    </fx:define>

                    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                style="-fx-background-color:transparent; -fx-border-color:transparent;">
                        <content>
                            <GridPane fx:id="gpKartuProduk" hgap="14" vgap="14">
                                <padding><Insets top="2" bottom="2" /></padding>
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="50" />
                                    <ColumnConstraints percentWidth="50" />
                                </columnConstraints>

                                <ToggleButton fx:id="cardPupukOrganikPadat"
                                              toggleGroup="$tgProduk"
                                              contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                              GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                <ToggleButton fx:id="cardPupukOrganikCair"
                                              toggleGroup="$tgProduk"
                                              contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                              GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                <ToggleButton fx:id="cardKompos"
                                              toggleGroup="$tgProduk"
                                              contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                              GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                <ToggleButton fx:id="cardBooster"
                                              toggleGroup="$tgProduk"
                                              contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                              GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                <ToggleButton fx:id="cardPupukNitrogen"
                                              toggleGroup="$tgProduk"
                                              contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                              GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                <ToggleButton fx:id="cardPupukKalsium"
                                              toggleGroup="$tgProduk"
                                              contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                              GridPane.columnIndex="1" GridPane.rowIndex="2" />
                            </GridPane>
                        </content>
                    </ScrollPane>
                </VBox>
            </HBox>

            <Separator>
                <VBox.margin><Insets bottom="10" top="14" /></VBox.margin>
            </Separator>
        </VBox>
    </children>
</AnchorPane>
