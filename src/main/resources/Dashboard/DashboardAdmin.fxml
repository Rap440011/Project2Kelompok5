<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0" stylesheets="@../Master/style.css"
            xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Dashboard.DashboardAdminController">

    <!-- ===================== SIDEBAR (KIRI) ===================== -->
    <left>
        <VBox prefWidth="230.0" spacing="6" styleClass="sidebar" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16" left="14" right="14" top="20" />
            </padding>

            <Label styleClass="sidebar-title" text="DASHBOARD ADMIN">
                <font>
                    <Font size="18.0" />
                </font>
            </Label>
            <Label styleClass="sidebar-title" text="Bumi Makmur" textFill="#C8E6C9">
                <font>
                    <Font size="12.0" />
                </font>
                <VBox.margin>
                    <Insets bottom="20" />
                </VBox.margin>
            </Label>

            <Separator styleClass="sidebar-separator" />

            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <VBox.margin>
                    <Insets top="14" />
                </VBox.margin>

                <Button fx:id="btnMenuKaryawan" mnemonicParsing="false" onAction="#handleMenuKaryawan"
                        prefHeight="40.0" styleClass="sidebar-btn" text="Master Karyawan" VBox.vgrow="NEVER" />

                <Button fx:id="btnMenuNasabah" mnemonicParsing="false" onAction="#handleMenuNasabah"
                        prefHeight="40.0" styleClass="sidebar-btn" text="Master Nasabah" />

                <Button fx:id="btnMenuProduk" mnemonicParsing="false" onAction="#handleMenuProduk"
                        prefHeight="40.0" styleClass="sidebar-btn" text="Master Produk" />

                <Button fx:id="btnMenuLimbah" mnemonicParsing="false" onAction="#handleMenuLimbah"
                        prefHeight="40.0" styleClass="sidebar-btn" text="Master Limbah" />
            </VBox>

            <Separator styleClass="sidebar-separator" />

            <Button fx:id="btnLogout" mnemonicParsing="false" onAction="#handleLogout"
                    prefHeight="40.0" styleClass="sidebar-logout" text="⏻  Logout">
                <VBox.margin>
                    <Insets top="10" />
                </VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- ===================== CONTENT AREA (KANAN) ===================== -->
    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16" left="16" right="16" top="16" />
            </padding>
        </StackPane>
    </center>

</BorderPane>
