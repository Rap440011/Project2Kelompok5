<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="700.0" prefWidth="1200.0"
            stylesheets="@../Master/style.css"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Dashboard.DashboardKasirController">

    <!-- ===================== SIDEBAR (KIRI) ===================== -->
    <left>
        <VBox prefWidth="230.0" spacing="6" styleClass="sidebar"
              BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16" left="14" right="14" top="20"/>
            </padding>

            <!-- Judul -->
            <Label styleClass="sidebar-title" text="DASHBOARD KASIR">
                <font><Font size="18.0"/></font>
            </Label>
            <Label styleClass="sidebar-title" text="Bumi Makmur" textFill="#C8E6C9">
                <font><Font size="12.0"/></font>
                <VBox.margin><Insets bottom="20"/></VBox.margin>
            </Label>

            <Separator styleClass="sidebar-separator"/>

            <!-- Menu Transaksi -->
            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <VBox.margin><Insets top="14"/></VBox.margin>

                <Label text="TRANSAKSI"
                       style="-fx-text-fill:#A5D6A7;-fx-font-size:10px;-fx-font-weight:bold;-fx-padding:4 0 2 4;"/>

                <Button fx:id="btnSetorLimbah"
                        mnemonicParsing="false"
                        onAction="#handleSetorLimbah"
                        prefHeight="40.0"
                        styleClass="sidebar-btn"
                        text="Setor Limbah"/>

                <Button fx:id="btnPengolahanLimbah"
                        mnemonicParsing="false"
                        onAction="#handlePengolahanLimbah"
                        prefHeight="40.0"
                        styleClass="sidebar-btn"
                        text="Pengolahan Limbah"/>

                <Button fx:id="btnPenjualan"
                        mnemonicParsing="false"
                        onAction="#handlePenjualan"
                        prefHeight="40.0"
                        styleClass="sidebar-btn"
                        text="Penjualan Produk"/>
            </VBox>

            <Separator styleClass="sidebar-separator"/>

            <!-- Logout -->
            <Button fx:id="btnLogout"
                    mnemonicParsing="false"
                    onAction="#handleLogout"
                    prefHeight="40.0"
                    styleClass="sidebar-logout"
                    text="⏻  Logout">
                <VBox.margin><Insets top="10"/></VBox.margin>
            </Button>
        </VBox>
    </left>

    <!-- ===================== CONTENT AREA (KANAN) ===================== -->
    <center>
        <StackPane fx:id="contentArea"
                   styleClass="content-area"
                   BorderPane.alignment="CENTER">
            <padding>
                <Insets bottom="16" left="16" right="16" top="16"/>
            </padding>
        </StackPane>
    </center>

</BorderPane>
