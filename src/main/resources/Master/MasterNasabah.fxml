<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootNasabah" prefHeight="700.0" prefWidth="1000.0" spacing="14" styleClass="content-card" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Master.MasterNasabahController">
    <padding>
        <Insets bottom="18" left="20" right="20" top="18" />
    </padding>

    <!-- HEADER + SEARCH -->
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label styleClass="page-title" text="Master Nasabah" />
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtCari" prefHeight="32.0" prefWidth="200.0" promptText="Cari nasabah..." />
        <Button fx:id="btnCari" mnemonicParsing="false" onAction="#handleCari" styleClass="btn,btn-cari" text="Cari" />
    </HBox>

    <!-- TABLE -->
    <TableView fx:id="tbNasabah" prefHeight="220.0" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="clmID" prefWidth="70.0" text="ID" />
            <TableColumn fx:id="clmNama" prefWidth="140.0" text="Nama Nasabah" />
            <TableColumn fx:id="clmHP" prefWidth="100.0" text="No. HP" />
            <TableColumn fx:id="clmRT" prefWidth="50.0" text="RT" />
            <TableColumn fx:id="clmRW" prefWidth="50.0" text="RW" />
            <TableColumn fx:id="clmKelurahan" prefWidth="100.0" text="Kelurahan" />
            <TableColumn fx:id="clmKecamatan" prefWidth="100.0" text="Kecamatan" />
            <TableColumn fx:id="clmKabupaten" prefWidth="100.0" text="Kabupaten" />
            <TableColumn fx:id="clmProvinsi" prefWidth="100.0" text="Provinsi" />
            <TableColumn fx:id="clmNoRek" prefWidth="110.0" text="No. Rekening" />
            <TableColumn fx:id="clmSaldo" prefWidth="100.0" text="Saldo" />
        </columns>
    </TableView>

    <!-- FORM -->
    <GridPane hgap="14" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="12" />
            <ColumnConstraints percentWidth="21" />
            <ColumnConstraints percentWidth="12" />
            <ColumnConstraints percentWidth="21" />
            <ColumnConstraints percentWidth="12" />
            <ColumnConstraints percentWidth="22" />
        </columnConstraints>

        <Label styleClass="field-label" text="ID Nasabah" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtID" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label styleClass="field-label" text="RT" GridPane.columnIndex="2" GridPane.rowIndex="4" />

        <Label styleClass="field-label" text="No. Rekening" GridPane.columnIndex="4" GridPane.rowIndex="0" />
        <TextField fx:id="txtNoRek" GridPane.columnIndex="5" GridPane.rowIndex="0" />

        <Label styleClass="field-label" text="Nama Nasabah" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtNama" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label styleClass="field-label" text="RW" GridPane.columnIndex="2" GridPane.rowIndex="5" />

        <Label styleClass="field-label" text="Saldo" GridPane.columnIndex="4" GridPane.rowIndex="1" />
        <TextField fx:id="txtSaldo" editable="false" GridPane.columnIndex="5" GridPane.rowIndex="1" />

        <Label styleClass="field-label" text="No. HP" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="txtHP" GridPane.columnIndex="1" GridPane.rowIndex="2" />
      <Label layoutX="653.0" layoutY="49.0" styleClass="field-label" text="Bank" GridPane.columnIndex="4" GridPane.rowIndex="2" />
      <ComboBox fx:id="cmbBank" prefHeight="25.0" prefWidth="350.0" GridPane.columnIndex="5" GridPane.rowIndex="2" />
      <ComboBox fx:id="cmbProvinsi" prefHeight="25.0" prefWidth="350.0" GridPane.columnIndex="3" />
      <ComboBox fx:id="cmbKabupaten" prefHeight="25.0" prefWidth="350.0" GridPane.columnIndex="3" GridPane.rowIndex="1" />
      <ComboBox fx:id="cmbKelurahan" prefHeight="25.0" prefWidth="350.0" GridPane.columnIndex="3" GridPane.rowIndex="2" />
      <ComboBox fx:id="cmbKecamatan" prefHeight="25.0" prefWidth="350.0" GridPane.columnIndex="3" GridPane.rowIndex="3" />
      <TextField fx:id="txtRT" GridPane.columnIndex="3" GridPane.rowIndex="4" />
      <TextField fx:id="txtRW" GridPane.columnIndex="3" GridPane.rowIndex="5" />
      <Label text="Provinsi" GridPane.columnIndex="2" />
      <Label text="Kabupaten" GridPane.columnIndex="2" GridPane.rowIndex="1" />
      <Label text="Kelurahan" GridPane.columnIndex="2" GridPane.rowIndex="2" />
      <Label text="Kecamatan" GridPane.columnIndex="2" GridPane.rowIndex="3" />
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>
    </GridPane>

    <!-- ACTION BUTTONS -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="btnBatal" mnemonicParsing="false" onAction="#handleBatal" styleClass="btn,btn-batal" text="Batal" />
        <Button fx:id="btnHapus" mnemonicParsing="false" onAction="#handleHapus" styleClass="btn,btn-hapus" text="Hapus" />
        <Button fx:id="btnUbah" mnemonicParsing="false" onAction="#handleUbah" styleClass="btn,btn-ubah" text="Ubah" />
        <Button fx:id="btnSimpan" mnemonicParsing="false" onAction="#handleSimpan" styleClass="btn,btn-simpan" text="Simpan" />
    </HBox>
</VBox>
