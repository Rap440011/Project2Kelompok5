<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootProduk" prefHeight="700.0" prefWidth="1040.0" spacing="14"
      styleClass="content-card" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Master.MasterProdukController">
    <padding>
        <Insets bottom="18" left="20" right="20" top="18" />
    </padding>

    <!-- HEADER -->
    <Label styleClass="page-title" text="Master Produk" />

    <!-- SEARCH BAR (memfilter kartu produk di bawah) -->
    <HBox alignment="CENTER_RIGHT" spacing="8">
        <children>
            <TextField fx:id="txtCari" prefHeight="32.0" prefWidth="280.0" promptText="Cari Produk..." />
            <Button fx:id="btnCari" mnemonicParsing="false" onAction="#handleCari" styleClass="btn,btn-cari" text="Cari" />
        </children>
    </HBox>

    <fx:define>
        <ToggleGroup fx:id="tgProdukTemplate" />
    </fx:define>

    <!-- DAFTAR PRODUK BERUPA KARTU GAMBAR, MENGISI AREA TENGAH (bekas tempat tabel) -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">
        <content>
            <FlowPane fx:id="fpKartuProduk" hgap="14" vgap="14">
                <children>
                    <ToggleButton fx:id="cardPupukOrganikPadat" toggleGroup="$tgProdukTemplate" contentDisplay="GRAPHIC_ONLY" />
                    <ToggleButton fx:id="cardPupukOrganikCair" toggleGroup="$tgProdukTemplate" contentDisplay="GRAPHIC_ONLY" />
                    <ToggleButton fx:id="cardKompos" toggleGroup="$tgProdukTemplate" contentDisplay="GRAPHIC_ONLY" />
                    <ToggleButton fx:id="cardBooster" toggleGroup="$tgProdukTemplate" contentDisplay="GRAPHIC_ONLY" />
                    <ToggleButton fx:id="cardPupukNitrogen" toggleGroup="$tgProdukTemplate" contentDisplay="GRAPHIC_ONLY" />
                    <ToggleButton fx:id="cardPupukKalsium" toggleGroup="$tgProdukTemplate" contentDisplay="GRAPHIC_ONLY" />
                </children>
            </FlowPane>
        </content>
    </ScrollPane>

    <!-- FORM -->
    <GridPane hgap="14" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="34" />
            <ColumnConstraints percentWidth="16" />
            <ColumnConstraints percentWidth="34" />
        </columnConstraints>

        <Label styleClass="field-label" text="ID Produk" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <!-- ID Produk otomatis & tidak bisa diisi manual -> tampil abu-abu -->
        <TextField fx:id="txtID" editable="false" style="-fx-background-color:#E4E4E4; -fx-opacity:1;" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label styleClass="field-label" text="Harga Jual" GridPane.columnIndex="2" GridPane.rowIndex="0" />
        <TextField fx:id="txtHrgJual" GridPane.columnIndex="3" GridPane.rowIndex="0" />

        <Label styleClass="field-label" text="Nama Produk" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="txtNama" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label styleClass="field-label" text="Satuan" GridPane.columnIndex="2" GridPane.rowIndex="1" />
        <ComboBox fx:id="cmbSatuan" maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="1" />

        <Label styleClass="field-label" text="Stock" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="txtStock" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label styleClass="field-label" text="Keterangan" GridPane.columnIndex="2" GridPane.rowIndex="2" />
        <TextArea fx:id="txtKeterangan" prefRowCount="2" wrapText="true" GridPane.columnIndex="3" GridPane.rowIndex="2" />
    </GridPane>

    <!-- ACTION BUTTONS -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button fx:id="btnBatal" mnemonicParsing="false" onAction="#handleBatal" styleClass="btn,btn-batal" text="Batal" />
        <Button fx:id="btnHapus" mnemonicParsing="false" onAction="#handleHapus" styleClass="btn,btn-hapus" text="Hapus" />
        <Button fx:id="btnUbah" mnemonicParsing="false" onAction="#handleUbah" styleClass="btn,btn-ubah" text="Ubah" />
        <Button fx:id="btnSimpan" mnemonicParsing="false" onAction="#handleSimpan" styleClass="btn,btn-simpan" text="Simpan" />
    </HBox>
</VBox>
