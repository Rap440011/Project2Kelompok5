<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootProduk"
      prefHeight="700.0" prefWidth="1040.0"
      spacing="0"
      styleClass="content-card"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Master.MasterProdukController">

    <!-- TOP BAR -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:transparent transparent #EBEBEB transparent;
                 -fx-border-width:0 0 1 0;">
        <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

        <Label text="" style="-fx-font-size:22px;" />
        <VBox spacing="1">
            <Label text="Master Produk"
                   style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1A1A1A;" />
            <Label text="Kelola data produk bank sampah"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <TextField fx:id="txtCari"
                   prefHeight="36" prefWidth="240"
                   promptText="🔍  Cari produk..."
                   style="-fx-background-radius:8; -fx-border-radius:8;
                          -fx-border-color:#E0E0E0; -fx-font-size:12px;" />
        <Button fx:id="btnCari"
                mnemonicParsing="false" onAction="#handleCari"
                text="Cari" prefHeight="36" prefWidth="72"
                styleClass="btn,btn-cari" />
    </HBox>

    <fx:define>
        <ToggleGroup fx:id="tgProdukTemplate" />
    </fx:define>

    <!-- KARTU PRODUK AREA -->
    <VBox VBox.vgrow="ALWAYS" style="-fx-background-color:#FAFAFA;">
        <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>

        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                    style="-fx-background-color:transparent; -fx-border-color:transparent;">
            <content>
                <GridPane fx:id="gpKartuProduk" hgap="14" vgap="14">
                    <padding><Insets top="2" bottom="2"/></padding>
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50" />
                        <ColumnConstraints percentWidth="50" />
                    </columnConstraints>
                    <ToggleButton fx:id="cardPupukOrganikPadat" toggleGroup="$tgProdukTemplate"
                                  contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                  GridPane.columnIndex="0" GridPane.rowIndex="0" />
                    <ToggleButton fx:id="cardPupukOrganikCair" toggleGroup="$tgProdukTemplate"
                                  contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0" />
                    <ToggleButton fx:id="cardKompos" toggleGroup="$tgProdukTemplate"
                                  contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1" />
                    <ToggleButton fx:id="cardBooster" toggleGroup="$tgProdukTemplate"
                                  contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    <ToggleButton fx:id="cardPupukNitrogen" toggleGroup="$tgProdukTemplate"
                                  contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                  GridPane.columnIndex="0" GridPane.rowIndex="2" />
                    <ToggleButton fx:id="cardPupukKalsium" toggleGroup="$tgProdukTemplate"
                                  contentDisplay="GRAPHIC_ONLY" maxWidth="Infinity"
                                  GridPane.columnIndex="1" GridPane.rowIndex="2" />
                </GridPane>
            </content>
        </ScrollPane>
    </VBox>

    <!-- FORM PANEL -->
    <VBox spacing="14"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:#EBEBEB transparent transparent transparent;
                 -fx-border-width:1 0 0 0;">
        <padding><Insets top="18" right="24" bottom="20" left="24"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <Region prefWidth="3" prefHeight="18"
                    style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
            <Label text="Detail Produk"
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333333;" />
        </HBox>

        <GridPane hgap="16" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="110" />
                <ColumnConstraints hgrow="ALWAYS" />
                <ColumnConstraints minWidth="100" prefWidth="110" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="32" />
                <RowConstraints minHeight="32" />
                <RowConstraints minHeight="60" />
            </rowConstraints>

            <Label text="ID Produk"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtID" editable="false"
                       style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                              -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Harga Jual"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="2" GridPane.rowIndex="0" />
            <TextField fx:id="txtHrgJual"
                       promptText="Rp 0"
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <Label text="Nama Produk"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="txtNama"
                       promptText="Nama produk..."
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Satuan"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="2" GridPane.rowIndex="1" />
            <ComboBox fx:id="cmbSatuan" maxWidth="Infinity"
                      GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <Label text="Stock"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="txtStock"
                       promptText="Jumlah stok..."
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Keterangan"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <TextArea fx:id="txtKeterangan" prefRowCount="2" wrapText="true"
                      promptText="Komposisi / keterangan produk..."
                      style="-fx-border-color:#E0E0E0; -fx-border-radius:6;
                             -fx-background-radius:6; -fx-font-size:12px;"
                      GridPane.columnIndex="3" GridPane.rowIndex="2" />
        </GridPane>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="btnBatal"  mnemonicParsing="false" onAction="#handleBatal"
                    styleClass="btn,btn-batal"  text="Batal"  prefWidth="100" prefHeight="36" />
            <Button fx:id="btnHapus"  mnemonicParsing="false" onAction="#handleHapus"
                    styleClass="btn,btn-hapus"  text="Hapus"  prefWidth="100" prefHeight="36" />
            <Button fx:id="btnUbah"   mnemonicParsing="false" onAction="#handleUbah"
                    styleClass="btn,btn-ubah"   text="Ubah"   prefWidth="100" prefHeight="36" />
            <Button fx:id="btnSimpan" mnemonicParsing="false" onAction="#handleSimpan"
                    styleClass="btn,btn-simpan" text="Simpan" prefWidth="100" prefHeight="36" />
        </HBox>
    </VBox>

</VBox>
