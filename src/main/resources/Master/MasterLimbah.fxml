<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootLimbah"
      prefHeight="700.0" prefWidth="1000.0"
      spacing="0"
      styleClass="content-card"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Master.MasterLimbahController">

    <!-- ══════════════════════════════════════════════════════════════════
         HEADER
    ═══════════════════════════════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#FFFFFF; -fx-border-color:transparent transparent #EBEBEB transparent; -fx-border-width:0 0 1 0;">
        <padding><Insets top="20" right="24" bottom="16" left="24" /></padding>

        <Label text="🗑" style="-fx-font-size:22px;" />
        <VBox spacing="1">
            <Label text="Master Limbah"
                   style="-fx-font-size:19px; -fx-font-weight:bold; -fx-text-fill:#1A1A1A;" />
            <Label text="Kelola data jenis limbah Bumi Makmur"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <TextField fx:id="txtCari"
                   prefHeight="36.0" prefWidth="240.0"
                   promptText="🔍  Cari limbah..."
                   style="-fx-background-radius:8; -fx-border-radius:8; -fx-border-color:#E0E0E0; -fx-font-size:12px;" />
        <Button fx:id="btnCari"
                mnemonicParsing="false" onAction="#handleCari"
                text="Cari"
                prefHeight="36" prefWidth="80"
                styleClass="btn,btn-cari" />
    </HBox>

    <!-- ══════════════════════════════════════════════════════════════════
         TABEL
    ═══════════════════════════════════════════════════════════════════ -->
    <VBox VBox.vgrow="ALWAYS"
          style="-fx-background-color:#FAFAFA;">
        <padding><Insets top="16" right="24" bottom="16" left="24" /></padding>

        <TableView fx:id="tbLimbah"
                   VBox.vgrow="ALWAYS"
                   style="-fx-background-color:white; -fx-border-color:#E8E8E8; -fx-border-radius:10; -fx-background-radius:10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 6, 0, 0, 2);">
            <columns>
                <TableColumn fx:id="clmID"
                             text="ID Limbah"
                             prefWidth="100"
                             style="-fx-alignment: CENTER"/>
                <TableColumn fx:id="clmNama"
                             text="Nama Limbah"
                             prefWidth="170"
                             style="-fx-alignment: CENTER"/>
                <TableColumn fx:id="clmKategori"
                             text="Kategori"
                             prefWidth="110"
                             style="-fx-alignment: CENTER"/>
                <TableColumn fx:id="clmJumlah"
                             text="Satuan"
                             prefWidth="100"
                             style="-fx-alignment: CENTER"/>
                <TableColumn fx:id="clmHarga"
                             text="Harga (Rp)"
                             prefWidth="130"
                             style="-fx-alignment: CENTER"/>
                <TableColumn fx:id="clmKeterangan"
                             text="Keterangan"
                             prefWidth="290"
                             style="-fx-alignment: CENTER"/>
            </columns>
        </TableView>
    </VBox>

    <!-- ══════════════════════════════════════════════════════════════════
         PANEL FORM
         Catatan: form ini SENGAJA tidak memakai GridPane. Setiap baris
         adalah HBox berisi beberapa "field group" (VBox) yang lebarnya
         dikunci penuh (minWidth = prefWidth = maxWidth) baik di FXML
         maupun di controller (lihat lockWidth() pada initialize()).
         Ini menghilangkan bug lama: saat dropdown ComboBox dibuka, form
         ikut melebar/tergeser karena GridPane menghitung ulang lebar
         kolom berdasarkan konten popup.
    ═══════════════════════════════════════════════════════════════════ -->
    <VBox spacing="18"
          style="-fx-background-color:#FFFFFF; -fx-border-color:#EBEBEB transparent transparent transparent; -fx-border-width:1 0 0 0;">
        <padding><Insets top="20" right="24" bottom="20" left="24" /></padding>

        <HBox alignment="CENTER_LEFT" spacing="8">
            <Region prefWidth="3" prefHeight="18"
                    style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
            <Label text="Detail Limbah"
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333333;" />
        </HBox>

        <!-- Row 0: ID Limbah | Nama Limbah -->
        <HBox spacing="24">
            <VBox spacing="6" minWidth="150" prefWidth="150" maxWidth="150">
                <Label text="ID Limbah"
                       style="-fx-font-size:12px; -fx-text-fill:#555555; -fx-font-weight:bold;" />
                <TextField fx:id="txtID" editable="false"
                           minWidth="150" prefWidth="150" maxWidth="150"
                           minHeight="34" prefHeight="34"
                           style="-fx-background-color:#F5F5F5; -fx-opacity:1; -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6; -fx-font-size:12px;" />
            </VBox>

            <VBox spacing="6" minWidth="420" prefWidth="420" maxWidth="420">
                <Label text="Nama Limbah"
                       style="-fx-font-size:12px; -fx-text-fill:#555555; -fx-font-weight:bold;" />
                <TextField fx:id="txtNama"
                           promptText="Contoh: Plastik, Kertas, Kaca"
                           minWidth="420" prefWidth="420" maxWidth="420"
                           minHeight="34" prefHeight="34"
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6; -fx-font-size:12px;" />
            </VBox>
        </HBox>

        <!-- Row 1: Kategori Limbah | Satuan | Harga -->
        <HBox spacing="24">
            <VBox spacing="6" minWidth="150" prefWidth="150" maxWidth="150">
                <Label text="Kategori Limbah"
                       style="-fx-font-size:12px; -fx-text-fill:#555555; -fx-font-weight:bold;" />
                <ComboBox fx:id="cmbjenis"
                          minWidth="150" prefWidth="150" maxWidth="150"
                          minHeight="34" prefHeight="34"
                          style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;" />
            </VBox>

            <VBox spacing="6" minWidth="150" prefWidth="150" maxWidth="150">
                <Label text="Satuan"
                       style="-fx-font-size:12px; -fx-text-fill:#555555; -fx-font-weight:bold;" />
                <TextField fx:id="txtJumlah"
                           promptText="Contoh: 100"
                           minWidth="150" prefWidth="150" maxWidth="150"
                           minHeight="34" prefHeight="34"
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6; -fx-font-size:12px;" />
            </VBox>

            <VBox spacing="6" minWidth="200" prefWidth="200" maxWidth="200">
                <Label text="Harga (Rp)"
                       style="-fx-font-size:12px; -fx-text-fill:#555555; -fx-font-weight:bold;" />
                <TextField fx:id="txtHarga"
                           promptText="Contoh: 5000"
                           minWidth="200" prefWidth="200" maxWidth="200"
                           minHeight="34" prefHeight="34"
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6; -fx-font-size:12px;" />
            </VBox>
        </HBox>

        <!-- Row 2: Keterangan full width -->
        <VBox spacing="6">
            <Label text="Keterangan"
                   style="-fx-font-size:12px; -fx-text-fill:#555555; -fx-font-weight:bold;" />
            <TextArea fx:id="txtketerangan"
                      prefRowCount="2" wrapText="true"
                      promptText="Tambahkan keterangan..."
                      style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6; -fx-font-size:12px;" />
        </VBox>

        <!-- ACTION BUTTONS -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="btnBatal"
                    mnemonicParsing="false" onAction="#handleBatal"
                    styleClass="btn,btn-batal"
                    text="Batal"
                    prefWidth="100" prefHeight="36" />
            <Button fx:id="btnHapus"
                    mnemonicParsing="false" onAction="#handleHapus"
                    styleClass="btn,btn-hapus"
                    text="Hapus"
                    prefWidth="100" prefHeight="36" />
            <Button fx:id="btnUbah"
                    mnemonicParsing="false" onAction="#handleUbah"
                    styleClass="btn,btn-ubah"
                    text="Ubah"
                    prefWidth="100" prefHeight="36" />
        </HBox>
    </VBox>
</VBox>
