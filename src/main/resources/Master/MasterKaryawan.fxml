<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootKaryawan"
      prefHeight="700.0" prefWidth="1000.0"
      spacing="0"
      styleClass="content-card"
      xmlns="http://javafx.com/javafx/26"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Master.MasterKaryawanController">

    <!-- TOP BAR -->
    <HBox alignment="CENTER_LEFT" spacing="12"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:transparent transparent #EBEBEB transparent;
                 -fx-border-width:0 0 1 0;">
        <padding><Insets top="20" right="24" bottom="16" left="24"/></padding>

        <VBox spacing="1">
            <Label text="Master Karyawan"
                   style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#1A1A1A;" />
            <Label text="Kelola data karyawan Bumi Makmur"
                   style="-fx-font-size:11px; -fx-text-fill:#9E9E9E;" />
        </VBox>

        <Region HBox.hgrow="ALWAYS" />

        <TextField fx:id="txtCari"
                   prefHeight="36" prefWidth="240"
                   promptText="🔍  Cari karyawan..."
                   style="-fx-background-radius:8; -fx-border-radius:8;
                          -fx-border-color:#E0E0E0; -fx-font-size:12px;" />
        <Button fx:id="btnCari"
                mnemonicParsing="false" onAction="#handleCari"
                text="Cari" prefHeight="36" prefWidth="72"
                styleClass="btn,btn-cari" />
    </HBox>

    <!-- FORM PANEL -->
    <VBox spacing="14"
          style="-fx-background-color:#FFFFFF;
                 -fx-border-color:#EBEBEB transparent transparent transparent;
                 -fx-border-width:1 0 0 0;">
        <padding><Insets top="18" right="24" bottom="20" left="24"/></padding>

        <!-- Sub-judul -->
        <HBox alignment="CENTER_LEFT" spacing="8">
            <Region prefWidth="3" prefHeight="18"
                    style="-fx-background-color:#2E7D32; -fx-background-radius:2;" />
            <Label text="Detail Karyawan"
                   style="-fx-font-size:13px; -fx-font-weight:bold; -fx-text-fill:#333333;" />
        </HBox>

        <!-- FORM: 6 kolom -->
        <GridPane hgap="16" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="90" prefWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="180" maxWidth="260" />
                <ColumnConstraints minWidth="90" prefWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="180" maxWidth="260" />
                <ColumnConstraints minWidth="90" prefWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" minWidth="180" maxWidth="260" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="32" />
                <RowConstraints minHeight="32" />
                <RowConstraints minHeight="32" />
                <RowConstraints minHeight="32" />
                <RowConstraints minHeight="32" />
            </rowConstraints>

            <!-- Baris 0: ID Karyawan | Provinsi | No. HP -->
            <Label text="ID Karyawan"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="txtID" editable="false"
                       style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                              -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="0">
                <Label text="Provinsi"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <ComboBox fx:id="cmbProvinsi" prefWidth="180" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="3" GridPane.rowIndex="0" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="4" GridPane.rowIndex="0">
                <Label text="No. HP"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <TextField fx:id="txtHP" promptText="08xxxxxxxxxx..."
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="5" GridPane.rowIndex="0" />

            <!-- Baris 1: Nama Karyawan | Kabupaten | Jabatan -->
            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="1">
                <Label text="Nama Karyawan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <TextField fx:id="txtNama" promptText="Nama lengkap..."
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="1">
                <Label text="Kabupaten"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <ComboBox fx:id="cmbKabupaten" prefWidth="180" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="3" GridPane.rowIndex="1" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="4" GridPane.rowIndex="1">
                <Label text="Jabatan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <ComboBox fx:id="cmbJabatan" prefWidth="180" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="5" GridPane.rowIndex="1" />

            <!-- Baris 2: Username | Kecamatan | Status -->
            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="2">
                <Label text="Username"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <TextField fx:id="txtUsn"
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="2">
                <Label text="Kecamatan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <ComboBox fx:id="cmbKecamatan" prefWidth="180" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="3" GridPane.rowIndex="2" />

            <Label text="Status"
                   style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;"
                   GridPane.columnIndex="4" GridPane.rowIndex="2" />
            <TextField fx:id="txtStatus" editable="false"
                       style="-fx-background-color:#F5F5F5; -fx-opacity:1;
                              -fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="5" GridPane.rowIndex="2" />

            <!-- Baris 3: Password | Kelurahan | Jenis Kelamin -->
            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="0" GridPane.rowIndex="3">
                <Label text="Password"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <TextField fx:id="txtPW"
                       style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;"
                       GridPane.columnIndex="1" GridPane.rowIndex="3" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="3">
                <Label text="Kelurahan"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <ComboBox fx:id="cmbKelurahan" prefWidth="180" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="3" GridPane.rowIndex="3" />

            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="4" GridPane.rowIndex="3">
                <Label text="Jenis Kelamin"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <ComboBox fx:id="cmbJK" prefWidth="180" maxWidth="1.7976931348623157E308"
                      GridPane.columnIndex="5" GridPane.rowIndex="3" />

            <!-- Baris 4: RT / RW -->
            <HBox spacing="2" alignment="CENTER_LEFT" GridPane.columnIndex="2" GridPane.rowIndex="4">
                <Label text="RT / RW"
                       style="-fx-font-size:12px; -fx-font-weight:bold; -fx-text-fill:#555;" />
                <Label text="*"
                       style="-fx-font-size:12px; -fx-text-fill:#E53935; -fx-font-weight:bold;" />
            </HBox>
            <HBox spacing="8" GridPane.columnIndex="3" GridPane.rowIndex="4">
                <TextField fx:id="txtRT" promptText="RT" prefWidth="80"
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;" />
                <Label text="/"
                       style="-fx-font-size:14px; -fx-text-fill:#999; -fx-padding:4 0 0 0;" />
                <TextField fx:id="txtRW" promptText="RW" prefWidth="80"
                           style="-fx-border-color:#E0E0E0; -fx-border-radius:6; -fx-background-radius:6;" />
            </HBox>
        </GridPane>

        <!-- ACTION BUTTONS -->
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button fx:id="btnBatal"  mnemonicParsing="false" onAction="#handleBatal"
                    styleClass="btn,btn-batal"  text="Batal"  prefWidth="100" prefHeight="36" />
            <Button fx:id="btnHapus"  mnemonicParsing="false" onAction="#handleHapus"
                    styleClass="btn,btn-hapus"  text="Hapus"  prefWidth="100" prefHeight="36"
                    disable="true" />
            <Button fx:id="btnUbah"   mnemonicParsing="false" onAction="#handleUbah"
                    styleClass="btn,btn-ubah"   text="Ubah"   prefWidth="100" prefHeight="36"
                    disable="true" />
            <Button fx:id="btnSimpan" mnemonicParsing="false" onAction="#handleSimpan"
                    styleClass="btn,btn-simpan" text="Simpan" prefWidth="100" prefHeight="36"
                    disable="true" />
        </HBox>
    </VBox>

    <!-- TABEL -->
    <TableView fx:id="tbKaryawan"
               VBox.vgrow="ALWAYS"
               style="-fx-background-color:white;
                      -fx-border-color:#E8E8E8 transparent transparent transparent;
                      -fx-border-width:0;">
        <padding><Insets top="0" right="24" bottom="0" left="24"/></padding>
        <columns>
            <TableColumn fx:id="clmNama"      text="Nama Karyawan"  prefWidth="200"
                         style="-fx-alignment:CENTER;" />
            <TableColumn fx:id="clmUsn"       text="Username"       prefWidth="150"
                         style="-fx-alignment:CENTER;" />
            <TableColumn fx:id="clmHP"        text="No. HP"         prefWidth="150"
                         style="-fx-alignment:CENTER;" />
            <TableColumn fx:id="clmJabatan"   text="Jabatan"        prefWidth="160"
                         style="-fx-alignment:CENTER;" />
            <TableColumn fx:id="clmJabatan1"  text="Status"         prefWidth="140"
                         style="-fx-alignment:CENTER;" />
            <TableColumn fx:id="clmJabatan11" text="Jenis Kelamin"  prefWidth="160"
                         style="-fx-alignment:CENTER;" />
        </columns>
    </TableView>

</VBox>
