<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.Group?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Ellipse?>
<?import javafx.scene.shape.Line?>

<AnchorPane prefHeight="500.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="Login.LoginController"
            onMousePressed="#handleMousePressed" onMouseDragged="#handleMouseDragged"
            styleClass="login-root">

    <stylesheets>
        <String fx:value="LoginStyle.css" />
    </stylesheets>

    <!-- KONTEN UTAMA (kiri gambar, kanan form) -->
    <HBox prefHeight="500.0" prefWidth="900.0" spacing="0"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0">

        <!-- LEFT SIDE: GAMBAR LOGIN -->
        <VBox prefHeight="500.0" prefWidth="450.0" alignment="CENTER" styleClass="login-left">
            <ImageView fitHeight="500.0" fitWidth="450.0" pickOnBounds="true" preserveRatio="false">
                <Image url="@GambarLogin1.png" />
            </ImageView>
        </VBox>

        <!-- RIGHT SIDE: FORM LOGIN -->
        <VBox prefHeight="500.0" prefWidth="450.0" spacing="20" alignment="TOP_CENTER" styleClass="login-right">
            <padding>
                <Insets top="40" left="40" right="40" bottom="40" />
            </padding>

            <!-- LOGO DAN JUDUL -->
            <VBox alignment="CENTER" spacing="10">
                <HBox alignment="CENTER" spacing="12">
                    <ImageView fitHeight="50.0" fitWidth="50.0" pickOnBounds="true" preserveRatio="true">
                        <Image url="@Logo.png" />
                    </ImageView>
                    <Label text="BUMI MAKMUR" styleClass="login-title" />
                </HBox>
            </VBox>

            <!-- USERNAME FIELD -->
            <VBox spacing="8">
                <Label text="Username" styleClass="label-field" />
                <TextField fx:id="txtUsername" prefHeight="40.0" promptText="Masukkan username" />
            </VBox>

            <!-- PASSWORD FIELD (dengan toggle show/hide) -->
            <VBox spacing="8">
                <Label text="Password" styleClass="label-field" />
                <StackPane>
                    <PasswordField fx:id="txtPassword" prefHeight="40.0" promptText="Masukkan password"
                                   styleClass="password-input" />
                    <TextField fx:id="txtPasswordVisible" prefHeight="40.0" promptText="Masukkan password"
                               styleClass="password-input" visible="false" managed="false" />

                    <Button fx:id="btnTogglePassword" styleClass="password-toggle-button"
                            mnemonicParsing="false" onAction="#handleTogglePassword"
                            StackPane.alignment="CENTER_RIGHT">
                        <StackPane.margin>
                            <Insets right="8" />
                        </StackPane.margin>
                        <graphic>
                            <StackPane>
                                <!-- ICON: MATA TERBUKA (password tersembunyi) -->
                                <Group fx:id="eyeOpenIcon">
                                    <Ellipse radiusX="7.5" radiusY="4.5" translateX="7.5" translateY="4.5"
                                             fill="TRANSPARENT" stroke="#777777" strokeWidth="1.3" />
                                    <Circle radius="2.0" translateX="7.5" translateY="4.5" fill="#777777" />
                                </Group>
                                <!-- ICON: MATA TERTUTUP (password terlihat) -->
                                <Group fx:id="eyeClosedIcon" visible="false">
                                    <Ellipse radiusX="7.5" radiusY="4.5" translateX="7.5" translateY="4.5"
                                             fill="TRANSPARENT" stroke="#777777" strokeWidth="1.3" />
                                    <Circle radius="2.0" translateX="7.5" translateY="4.5" fill="#777777" />
                                    <Line startX="0" startY="9" endX="15" endY="0" stroke="#777777" strokeWidth="1.3" />
                                </Group>
                            </StackPane>
                        </graphic>
                    </Button>
                </StackPane>
            </VBox>

            <!-- ERROR LABEL -->
            <Label fx:id="lblError" styleClass="error-label" visible="false" wrapText="true" />

            <!-- LOGIN BUTTON -->
            <Button fx:id="btnLogin" maxWidth="Infinity" prefHeight="45.0" text="Masuk"
                    styleClass="button" mnemonicParsing="false" onAction="#handleLoginAction" />

            <VBox.margin>
                <Insets top="10" />
            </VBox.margin>
        </VBox>
    </HBox>

    <!-- TOMBOL CLOSE CUSTOM (karena window tanpa title bar) -->
    <Button fx:id="btnClose" text="&#10005;" styleClass="close-button" mnemonicParsing="false"
            onAction="#handleClose"
            AnchorPane.topAnchor="10" AnchorPane.rightAnchor="10" />

</AnchorPane>
